# ============================================================
#  Smart Event Management System — .gitignore
# ============================================================

# ----------------------------
# Dependencies
# ----------------------------
node_modules/
.pnp
.pnp.js

# ----------------------------
# Environment Variables
# ----------------------------
.env
.env.*
!.env.example

# ----------------------------
# Build Output
# ----------------------------
dist/
build/
.vite/
out/

# ----------------------------
# Local MongoDB Data
# ----------------------------
backend/data/db/
*.wt
*.lock
WiredTiger*
mongod.lock
diagnostic.data/
journal/

# ----------------------------
# Logs
# ----------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
backend_error.txt
backend_log.txt
backend_persistent_log.txt

# ----------------------------
# Temp / Debug / Dev Scripts
# (one-off scripts used during development)
# ----------------------------
conflicts.txt
unmerged.txt
temp*.txt
status*.txt
git_status*.txt
git-status*.txt
cleanUrls.js
fixBacktick.js
fixQuotes.js
fixQuotes2.js
fixRegex.js
fixTicks.js
replaceUrl.js
fixQuotes*.js
backend_error.txt
backend_log.txt
backend_persistent_log.txt

# ----------------------------
# Frontend Debug Output
# ----------------------------
frontend/all_errors.txt
frontend/audit_log*.txt
frontend/build_output*.txt
frontend/dev_output.txt
frontend/error*.txt
frontend/errors*.txt
frontend/eslint_out.json
frontend/eslint_output.txt
frontend/lint*.txt
frontend/out.txt
frontend/vite_build_output.txt
frontend/lint_results.json

# ----------------------------
# Testing / Coverage
# ----------------------------
coverage/
*.lcov
.nyc_output/

# ----------------------------
# OS & Editor Files
# ----------------------------
.DS_Store
Thumbs.db
Desktop.ini
.vscode/mongodb-connections.json
*.suo
*.ntvs*
*.njsproj
*.sln

# ----------------------------
# Misc Generated / Temp Files
# ----------------------------
temp_ar_repo
*.backup
backend/.env.backup
vercel.json

# ----------------------------
# Deployment Cache
# ----------------------------
.vercel
.netlify
