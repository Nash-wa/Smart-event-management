# ============================================================
#  Smart Event Management System — .gitignore
# ============================================================

# ----------------------------
# Dependencies
# ----------------------------
node_modules/
backend/node_modules/
frontend/node_modules/
.venv/
.pnp
.pnp.js

# ----------------------------
# Environment Variables
# ----------------------------
.env
.env.*
backend/.env
frontend/.env
*.env.local
!.env.example

# ----------------------------
# Build Output
# ----------------------------
dist/
frontend/dist/
build/
.next/
.vite/
out/
.vercel
.netlify

# ----------------------------
# Local MongoDB Data
# ----------------------------
backend/data/db/
*.wt
*.lock
WiredTiger*
mongod.lock
diagnostic.data/
journal/

# ----------------------------
# Logs & Debug Output
# ----------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
backend_error.txt
backend_log.txt
backend_persistent_log.txt
frontend/all_errors.txt
frontend/audit_log*.txt
frontend/build_output*.txt
frontend/dev_output.txt
frontend/error*.txt
frontend/errors*.txt
frontend/eslint_out.json
frontend/eslint_output.txt
frontend/lint*.txt
frontend/out.txt
frontend/vite_build_output.txt
frontend/lint_results.json
conflicts.txt
unmerged.txt
temp*.txt
status*.txt
git_status*.txt
git-status*.txt

# ----------------------------
# Temp / Dev Scripts
# ----------------------------
cleanUrls.js
fixBacktick.js
fixQuotes.js
fixQuotes2.js
fixRegex.js
fixTicks.js
replaceUrl.js
fixQuotes*.js
temp_ar_repo
*.backup
backend/.env.backup
vercel.json

# ----------------------------
# Databases & Coverage
# ----------------------------
*.sqlite
*.db
coverage/
*.lcov
.nyc_output/

# ----------------------------
